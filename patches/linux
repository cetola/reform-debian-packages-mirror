++{
++	u32 *packet32, len32;
++	u32 val, i;
++	
++	printk(KERN_ALERT "DEBUG: %s %d \n",__FUNCTION__,__LINE__);
++
++	/* invalidate entry */
++	val = F_ACTIVE_IDLE_TYPE(1) | F_PKT_ALLOC_ADDRESS(entry_id);
