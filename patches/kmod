++          </para>
++        </listitem>
++      </varlistentry>
++      <varlistentry>
++        <term>
++          <option>-w</option>
++        </term>
++        <listitem>
++          <para>
++            Warn on duplicate dependencies, aliases, symbol versions, etc.
++          </para>
++        </listitem>
++      </varlistentry>
