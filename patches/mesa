new file mode 100644
index 000000000000..0c25e15e4cba
--- /dev/null
+++ b/src/panfrost/compiler/pan_fast_link.c
@@ -0,0 +1,87 @@
+/*
+ * Copyright © 2026 Google, Inc.
+ * SPDX-License-Identifier: MIT
+ */
+
+#include "pan_fast_link.h"
+#include <string.h>
+#include "valhall_enums.h"
+
+/* Patch the flow control bits of the instruction at the given byte
+ * offset, replacing VA_FLOW_END with VA_FLOW_NONE so execution falls
+ * through to the next concatenated binary. */
+static void
+patch_flow_end(void *binary, unsigned instr_offset)
+{
+   uint64_t *instr = (uint64_t *)((uint8_t *)binary + instr_offset);
+   uint64_t flow_mask = (uint64_t)0x1f << 59;
+
+   assert((*instr & flow_mask) == ((uint64_t)VA_FLOW_END << 59));
+   *instr = (*instr & ~flow_mask) | ((uint64_t)VA_FLOW_NONE << 59);
+}
+
+bool
+pan_fast_link(struct pan_linked_shader *linked,
+              const struct pan_shader_part *prolog,
+              const struct pan_shader_part *main,
+              const struct pan_shader_part *epilog)
+{
+   assert(main && main->binary && main->size > 0);
+
+   bool has_prolog = prolog && prolog->size > 0;
+   bool has_epilog = epilog && epilog->size > 0;
+
+   /* For non-final shader parts, only copy up to and including the last
+    * real instruction (last_instr_offset + 8), stripping 128-byte alignment
+    * padding. The padding is zero-filled which is NOT a valid Valhall
+    * instruction encoding -- executing it causes INSTR_INVALID_ENC.
+    *
+    * The final part keeps its full size (including padding + VA_FLOW_END).
+    */
+   unsigned prolog_copy = has_prolog ? prolog->last_instr_offset + 8 : 0;
+   unsigned main_copy = has_epilog ? main->last_instr_offset + 8 : main->size;
+   unsigned epilog_copy = has_epilog ? epilog->size : 0;
+   unsigned total_size = prolog_copy + main_copy + epilog_copy;
+
+   linked->binary = malloc(total_size);
+   if (!linked->binary)
+      return false;
+
+   linked->size = total_size;
+   linked->work_reg_count = main->work_reg_count;
+
+   unsigned offset = 0;
+
+   /* Copy prolog (stripped of trailing padding) */
+   if (has_prolog) {
+      memcpy(linked->binary, prolog->binary, prolog_copy);
+      patch_flow_end(linked->binary, prolog->last_instr_offset);
+      linked->work_reg_count =
+         MAX2(linked->work_reg_count, prolog->work_reg_count);
+      offset += prolog_copy;
+   }
+
+   /* Copy main */
+   memcpy((uint8_t *)linked->binary + offset, main->binary, main_copy);
+
+   /* If there's an epilog, patch main's flow end and append epilog */
+   if (has_epilog) {
+      patch_flow_end((uint8_t *)linked->binary + offset,
+                     main->last_instr_offset);
+      offset += main_copy;
+
+      memcpy((uint8_t *)linked->binary + offset, epilog->binary, epilog_copy);
+      linked->work_reg_count =
+         MAX2(linked->work_reg_count, epilog->work_reg_count);
+   }
+
+   return true;
+}
+
+void
+pan_fast_link_cleanup(struct pan_linked_shader *linked)
+{
+   free(linked->binary);
+   linked->binary = NULL;
+   linked->size = 0;
+}
