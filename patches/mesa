+   unsigned size;
+   unsigned last_instr_offset;
+   unsigned work_reg_count;
+};
+
+struct pan_linked_shader {
+   void *binary;
+   unsigned size;
+   unsigned work_reg_count;
+};
+
+bool pan_fast_link(struct pan_linked_shader *linked,
+                   const struct pan_shader_part *prolog,
+                   const struct pan_shader_part *main,
+                   const struct pan_shader_part *epilog);
+
+void pan_fast_link_cleanup(struct pan_linked_shader *linked);
