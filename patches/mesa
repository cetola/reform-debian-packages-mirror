+/* Build a standalone fragment shader prolog that interpolates clip distances
+ * from the VAR slots the VS remapped them to (compact=false, one varying slot
+ * per clip distance) and demotes fragments where any clip distance is
+ * negative.  The prolog is compiled against the VS's varying layout and
+ * concatenated with the main FS by pan_fast_link().
+ */
+nir_shader *
+pan_nir_build_fs_prolog(const struct panvk_fs_prolog_key *key,
+                        const nir_shader_compiler_options *options)
+{
+   assert(key->clip_distance_array_size > 0);
+   assert(key->clip_distance_array_size <= 8);
+
+   nir_builder b = nir_builder_init_simple_shader(MESA_SHADER_FRAGMENT, options,
+                                                  "pan-fs-clip-prolog");
+
+   b.shader->info.io_lowered = true;
+
+   nir_def *barycentric =
+      nir_load_barycentric(&b, nir_intrinsic_load_barycentric_pixel,
+                           INTERP_MODE_NONE);
+
+   /* The VS stores clip_dist * W; the hardware loads with perspective-correct
+    * interpolation.  Multiply by fragcoord_w to recover linear values. */
+   nir_def *fragcoord_w =
+      nir_load_var_special_pan(&b, 1, barycentric,
+                               .flags = BI_VARYING_NAME_FRAG_W);
+
+   nir_def *cond = NULL;
+   for (unsigned i = 0; i < key->clip_distance_array_size; i++) {
+      unsigned var_slot = VARYING_SLOT_VAR0 + key->clip_dist_var_slot + i;
+
+      nir_def *load =
+         nir_load_interpolated_input(&b, 1, 32, barycentric,
+                                     nir_imm_int(&b, 0),
+                                     .base = 0,
+                                     .io_semantics.location = var_slot,
+                                     .io_semantics.num_slots = 1);
+
+      nir_def *clipdist = nir_fmul(&b, load, fragcoord_w);
+      nir_def *negative = nir_flt_imm(&b, clipdist, 0.0);
+      cond = cond ? nir_ior(&b, cond, negative) : negative;
+
+      b.shader->info.inputs_read |= BITFIELD64_BIT(var_slot);
+   }
+
+   nir_demote_if(&b, cond);
+   b.shader->info.fs.uses_discard = true;
+
+   return b.shader;
+}
+
+/* Mali only supports perspective-correct or flat interpolation. To get linear
+ * interpolation for clip distances (required by Vulkan), the VS stores
+ * (clip_dist * W) and the FS divides out by multiplying by FragCoord.w after
+ * perspective-correct interpolation.
+ *
+ * pan_nir_lower_clip_distance_vs must run before nir_lower_viewport_transform
+ * so position W is the raw clip-space W (not 1/W).
+ */
+
+struct vs_lower_clip_data {
+   nir_def *pos_w;
+   unsigned base_loc;
+   unsigned array_size;
+};
+
+static bool
+multiply_clip_store_by_pos_w(nir_builder *b, nir_intrinsic_instr *intrin,
+                             void *data)
+{
+   struct vs_lower_clip_data *d = data;
+
+   if (intrin->intrinsic != nir_intrinsic_store_output)
+      return false;
+
+   unsigned loc = nir_intrinsic_io_semantics(intrin).location;
+   if (loc < d->base_loc || loc >= d->base_loc + d->array_size)
+      return false;
+
+   b->cursor = nir_before_instr(&intrin->instr);
+   nir_def *scaled = nir_fmul(b, intrin->src[0].ssa, d->pos_w);
+   nir_src_rewrite(&intrin->src[0], scaled);
+
+   return true;
+}
+
+bool
+pan_nir_lower_clip_distance_vs(nir_shader *shader, unsigned clip_dist_var_slot,
+                               unsigned clip_distance_array_size)
+{
+   assert(shader->info.stage == MESA_SHADER_VERTEX);
+
+   if (clip_distance_array_size == 0)
+      return false;
+
+   if (!(shader->info.outputs_written & VARYING_BIT_POS))
+      return false;
+
+   nir_function_impl *impl = nir_shader_get_entrypoint(shader);
+   nir_intrinsic_instr *pos_store = pan_nir_find_pos_store(impl);
+   if (!pos_store)
+      return false;
+
+   nir_builder b = nir_builder_at(nir_after_instr(&pos_store->instr));
+   nir_def *pos_w = nir_channel(&b, pos_store->src[0].ssa, 3);
+
+   pan_nir_move_output_stores_after(nir_def_instr(pos_w));
+
+   struct vs_lower_clip_data data = {
+      .pos_w = pos_w,
+      .base_loc = VARYING_SLOT_VAR0 + clip_dist_var_slot,
+      .array_size = clip_distance_array_size,
+   };
+   return nir_shader_intrinsics_pass(shader, multiply_clip_store_by_pos_w,
+                                     nir_metadata_control_flow, &data);
+}
+
+struct fs_lower_clip_data {
+   unsigned base_loc;
+   unsigned array_size;
+};
+
+static bool
+lower_clip_distance_fs_instr(nir_builder *b, nir_intrinsic_instr *intrin,
+                             void *data)
+{
+   struct fs_lower_clip_data *d = data;
+
+   if (intrin->intrinsic != nir_intrinsic_load_interpolated_input)
+      return false;
+
+   unsigned loc = nir_intrinsic_io_semantics(intrin).location;
+   if (loc < d->base_loc || loc >= d->base_loc + d->array_size)
+      return false;
+
+   b->cursor = nir_after_instr(&intrin->instr);
+   nir_def *fragcoord = nir_load_frag_coord(b);
+   nir_def *fragcoord_w = nir_channel(b, fragcoord, 3);
+   nir_def *corrected = nir_fmul(b, &intrin->def, fragcoord_w);
+
+   nir_def_rewrite_uses_after(&intrin->def, corrected);
+
+   return true;
+}
+
+bool
+pan_nir_lower_clip_distance_fs(nir_shader *shader, unsigned clip_dist_var_slot,
+                               unsigned clip_distance_array_size)
+{
+   assert(shader->info.stage == MESA_SHADER_FRAGMENT);
+
+   if (clip_distance_array_size == 0)
+      return false;
+
+   struct fs_lower_clip_data data = {
+      .base_loc = VARYING_SLOT_VAR0 + clip_dist_var_slot,
+      .array_size = clip_distance_array_size,
+   };
+   return nir_shader_intrinsics_pass(shader, lower_clip_distance_fs_instr,
+                                     nir_metadata_control_flow, &data);
+}
