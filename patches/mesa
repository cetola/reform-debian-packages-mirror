+/* Compile a clip distance FS prolog and fast-link it with the main FS.
+ * Returns the linked cache entry with the combined binary and SPD, or
+ * NULL if no prolog is needed (clip_distance_array_size == 0).
+ */
+static struct panvk_linked_shader_entry *
+link_fs_clip_prolog(struct panvk_cmd_buffer *cmdbuf,
+                    const struct panvk_shader_variant *fs)
+{
+   const struct panvk_shader_variant *vs =
+      panvk_shader_hw_variant(cmdbuf->state.gfx.vs.shader);
+
+   if (!vs || vs->vs.clip_distance_array_size == 0)
+      return NULL;
+
+   struct panvk_device *dev = to_panvk_device(cmdbuf->vk.base.device);
+
+   /* Build the cache key from the main FS binary pointer and the VS
+    * clip distance parameters.
+    */
+   struct panvk_linked_shader_key key = {
+      .main_binary = fs->bin_ptr,
+      .fs_prolog =
+         {
+            .clip_distance_array_size = vs->vs.clip_distance_array_size,
+            .clip_dist_var_slot = vs->vs.clip_dist_var_slot,
+         },
+   };
+
+   /* Fast path: cache hit */
+   struct panvk_linked_shader_entry *entry =
+      panvk_linked_shader_cache_lookup(&dev->linked_shader_cache, &key);
+   if (entry)
+      return entry;
+
+   /* Cache miss: build, compile and link the prolog */
+   struct panvk_physical_device *phys_dev =
+      to_panvk_physical_device(dev->vk.physical);
+   unsigned gpu_id = phys_dev->kmod.dev->props.gpu_id;
+   const nir_shader_compiler_options *nir_options =
+      pan_get_nir_shader_compiler_options(pan_arch(gpu_id));
+
+   nir_shader *prolog_nir =
+      pan_nir_build_fs_prolog(&key.fs_prolog, nir_options);
+
+   struct pan_compile_inputs prolog_inputs = {
+      .gpu_id = gpu_id,
+      .gpu_variant = phys_dev->kmod.dev->props.gpu_variant,
+      /* The prolog must not emit ATEST -- the main FS already has one.
+       * A double ATEST would overwrite the coverage set by the prolog. */
+      .skip_atest = true,
+      /* Must match the main FS varying load mechanism so the prolog
+       * uses the same instruction path (LD_VAR_BUF vs LD_VAR). */
+      .valhall.use_ld_var_buf = fs->desc_info.fs_varying_attr_desc_count == 0,
+   };
+
+   struct util_dynarray prolog_binary = UTIL_DYNARRAY_INIT;
+   struct pan_shader_info prolog_info = {0};
+
+   panvk_per_arch(compiler_lock)();
+   pan_postprocess_nir(prolog_nir, gpu_id);
+   pan_shader_compile(prolog_nir, &prolog_inputs, &prolog_binary, &prolog_info);
+   panvk_per_arch(compiler_unlock)();
+
+   /* Set up fast-link parts */
+   struct pan_shader_part prolog_part = {
+      .binary = util_dynarray_element(&prolog_binary, uint8_t, 0),
+      .size = util_dynarray_num_elements(&prolog_binary, uint8_t),
+      .last_instr_offset = prolog_info.last_instr_offset,
+      .work_reg_count = prolog_info.work_reg_count,
+   };
+
+   struct pan_shader_part main_part = {
+      .binary = fs->bin_ptr,
+      .size = fs->bin_size,
+      .last_instr_offset = fs->info.last_instr_offset,
+      .work_reg_count = fs->info.work_reg_count,
+   };
+
+   struct pan_linked_shader linked = {0};
+   bool ok = pan_fast_link(&linked, &prolog_part, &main_part, NULL);
+
+   ralloc_free(prolog_nir);
+   util_dynarray_fini(&prolog_binary);
+
+   if (!ok)
+      return NULL;
+
+   /* Insert into cache (this uploads the binary and handles races) */
+   entry = panvk_linked_shader_cache_insert(&dev->linked_shader_cache, dev,
+                                            &key, &linked);
+
+   pan_fast_link_cleanup(&linked);
+
+   if (!entry)
+      return NULL;
+
+   /* Build the SPD for the linked shader if not yet done */
+   if (!panvk_priv_mem_check_alloc(entry->spd)) {
+      entry->spd = panvk_pool_alloc_desc(&dev->mempools.rw, SHADER_PROGRAM);
+      if (!panvk_priv_mem_check_alloc(entry->spd))
+         return NULL;
+
+      panvk_priv_mem_write_desc(entry->spd, 0, SHADER_PROGRAM, cfg) {
+         cfg.stage = MALI_SHADER_STAGE_FRAGMENT;
+         cfg.fragment_coverage_bitmask_type = MALI_COVERAGE_BITMASK_TYPE_GL;
+         cfg.register_allocation =
+            pan_register_allocation(entry->work_reg_count);
+         cfg.binary = panvk_priv_mem_dev_addr(entry->code_mem);
+         cfg.preload.r48_r63 = (fs->info.preload >> 48);
