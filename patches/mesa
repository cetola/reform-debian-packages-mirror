+static inline nir_intrinsic_instr *
+pan_nir_find_pos_store(nir_function_impl *impl)
+{
+   nir_block *block = nir_impl_last_block(impl);
+   nir_foreach_instr(instr, block) {
+      if (instr->type != nir_instr_type_intrinsic)
+         continue;
+      nir_intrinsic_instr *intrin = nir_instr_as_intrinsic(instr);
+
+      if (intrin->intrinsic != nir_intrinsic_store_output)
+         continue;
+
+      nir_io_semantics sem = nir_intrinsic_io_semantics(intrin);
+      if (sem.location == VARYING_SLOT_POS)
+         return intrin;
+   }
+
+   return NULL;
+}
+
+/* Move all store_output instructions in @after's block that precede @after to
+ * after it, so a value defined at @after dominates subsequent store rewrites.
+ */
+static inline void
+pan_nir_move_output_stores_after(nir_instr *after)
+{
