diff --git a/src/panfrost/compiler/pan_nir_prolog_epilog.c b/src/panfrost/compiler/pan_nir_prolog_epilog.c
index a50e372755c9..aafd0dd085a9 100644
--- a/src/panfrost/compiler/pan_nir_prolog_epilog.c
+++ b/src/panfrost/compiler/pan_nir_prolog_epilog.c
@@ -68,3 +68,129 @@ pan_nir_build_fs_prolog(const struct panvk_fs_prolog_key *key,
 
    return b.shader;
 }
+
+/* Multiply clip distance store_outputs by position W for correct linear
+ * interpolation on Mali hardware.
+ *
+ * Mali only supports perspective-correct or flat varying interpolation.
+ * Clip distances must be linearly interpolated per the Vulkan spec. To get
+ * linear interpolation from perspective-correct hardware, the VS stores
+ * (clip_dist * W) and the FS loads with perspective-correct interpolation
+ * then multiplies by fragcoord_w to recover linear values.
+ *
+ * This pass handles the VS side. It must run before
+ * nir_lower_viewport_transform so that position W is the raw clip-space W.
+ */
+bool
+pan_nir_lower_clip_distance_vs(nir_shader *shader, unsigned clip_dist_var_slot,
+                               unsigned clip_distance_array_size)
+{
+   assert(shader->info.stage == MESA_SHADER_VERTEX);
+
+   if (clip_distance_array_size == 0)
+      return false;
+
+   if (!(shader->info.outputs_written & VARYING_BIT_POS))
+      return false;
+
+   nir_function_impl *impl = nir_shader_get_entrypoint(shader);
+   nir_intrinsic_instr *pos_store = pan_nir_find_pos_store(impl);
+   if (!pos_store)
+      return false;
+
+   /* Before nir_lower_viewport_transform, position W is the raw clip-space W.
+    * We multiply clip distances by W directly (no frcp needed).
+    */
+   nir_builder b = nir_builder_at(nir_after_instr(&pos_store->instr));
+   nir_def *pos_w = nir_channel(&b, pos_store->src[0].ssa, 3);
+
+   /* Move all output stores after pos_w to ensure SSA dominance */
+   nir_cursor cursor = nir_after_instr(nir_def_instr(pos_w));
+   nir_block *block = nir_impl_last_block(impl);
+   nir_foreach_instr_safe(instr, block)
+   {
+      if (instr == nir_def_instr(pos_w))
+         break;
+
+      if (instr->type != nir_instr_type_intrinsic)
+         continue;
+
+      nir_intrinsic_instr *intrin = nir_instr_as_intrinsic(instr);
+
+      if (intrin->intrinsic == nir_intrinsic_store_output)
+         nir_instr_move(cursor, instr);
+   }
+
+   /* Multiply clip distance stores by W. Each clip distance occupies its own
+    * varying slot (compact=false after remapping).
+    */
+   unsigned base_loc = VARYING_SLOT_VAR0 + clip_dist_var_slot;
+
+   nir_foreach_instr_safe(instr, block)
+   {
+      if (instr->type != nir_instr_type_intrinsic)
+         continue;
+
+      nir_intrinsic_instr *intrin = nir_instr_as_intrinsic(instr);
+
+      if (intrin->intrinsic != nir_intrinsic_store_output)
+         continue;
+
+      unsigned loc = nir_intrinsic_io_semantics(intrin).location;
+      if (loc < base_loc || loc >= base_loc + clip_distance_array_size)
+         continue;
+
+      b.cursor = nir_before_instr(&intrin->instr);
+      nir_def *old_value = intrin->src[0].ssa;
+      nir_def *new_value = nir_fmul(&b, old_value, pos_w);
+      nir_src_rewrite(&intrin->src[0], new_value);
+   }
+
+   nir_progress(true, impl, nir_metadata_control_flow);
+
+   return true;
+}
+
+/* Lower clip distance input reads in the fragment shader.
+ *
+ * The VS stores clip_dist * W at the remapped varying slots. The hardware
+ * loads them with perspective-correct interpolation. To recover the linearly
+ * interpolated clip distance, multiply by gl_FragCoord.w.
+ */
+static bool
+lower_clip_distance_fs_instr(nir_builder *b, nir_intrinsic_instr *intrin,
+                             void *data)
+{
+   unsigned *params = data;
+   unsigned base_loc = VARYING_SLOT_VAR0 + params[0];
+   unsigned array_size = params[1];
+
+   if (intrin->intrinsic != nir_intrinsic_load_interpolated_input)
+      return false;
+
+   unsigned loc = nir_intrinsic_io_semantics(intrin).location;
+   if (loc < base_loc || loc >= base_loc + array_size)
+      return false;
+
+   b->cursor = nir_after_instr(&intrin->instr);
+   nir_def *fragcoord = nir_load_frag_coord(b);
+   nir_def *fragcoord_w = nir_channel(b, fragcoord, 3);
+   nir_def *corrected = nir_fmul(b, &intrin->def, fragcoord_w);
+
+   nir_def_rewrite_uses_after(&intrin->def, corrected);
+   return true;
+}
+
+bool
+pan_nir_lower_clip_distance_fs(nir_shader *shader, unsigned clip_dist_var_slot,
+                               unsigned clip_distance_array_size)
+{
+   assert(shader->info.stage == MESA_SHADER_FRAGMENT);
+
+   if (clip_distance_array_size == 0)
+      return false;
+
+   unsigned params[2] = {clip_dist_var_slot, clip_distance_array_size};
+   return nir_shader_intrinsics_pass(shader, lower_clip_distance_fs_instr,
+                                     nir_metadata_control_flow, params);
+}
