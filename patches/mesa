+/*
+ * Copyright © 2026 Google, Inc.
+ * SPDX-License-Identifier: MIT
+ */
+
+#include "pan_nir_prolog_epilog.h"
+#include "compiler/nir/nir_builder.h"
+#include "compiler/shader_enums.h"
+#include "pan_nir.h"
+
+/* Build a standalone fragment shader prolog that interpolates clip distance
+ * varyings and discards fragments where any clip distance is negative.
+ *
+ * This replicates the logic of lower_clip_fs() from nir_lower_clip.c but as
+ * a standalone shader that can be compiled independently and concatenated with
+ * the main FS via pan_fast_link().
+ */
+nir_shader *
+pan_nir_build_fs_prolog(const struct panvk_fs_prolog_key *key,
+                        const nir_shader_compiler_options *options)
+{
+   assert(key->clip_distance_array_size > 0);
+   assert(key->clip_distance_array_size <= 8);
+
+   nir_builder b = nir_builder_init_simple_shader(MESA_SHADER_FRAGMENT, options,
+                                                  "pan-fs-clip-prolog");
+
+   b.shader->info.io_lowered = true;
+
+   /* Get barycentric coordinates for interpolation */
+   nir_def *barycentric = nir_load_barycentric(
+      &b, nir_intrinsic_load_barycentric_pixel, INTERP_MODE_NONE);
+
+   nir_def *clipdist[8] = {NULL};
+
+   /* Each clip distance occupies its own varying slot (compact=false after
+    * remapping from CLIP_DIST0/1 to VAR slots). Load each one individually.
+    *
+    * The VS multiplied clip distances by W (see pan_nir_lower_clip_distance_vs)
+    * so they are stored as clip_dist * W. The hardware loads them with
+    * perspective-correct interpolation. We multiply by fragcoord_w to recover
+    * the linearly interpolated value.
+    */
+   nir_def *fragcoord_w =
+      nir_load_frag_coord_zw_pan(&b, barycentric, .component = 3);
+
+   for (unsigned i = 0; i < key->clip_distance_array_size; i++) {
+      unsigned var_slot = VARYING_SLOT_VAR0 + key->clip_dist_var_slot + i;
+
+      nir_def *load = nir_load_interpolated_input(
+         &b, 1, 32, barycentric, nir_imm_int(&b, 0), .base = 0,
+         .io_semantics.location = var_slot, .io_semantics.num_slots = 1);
+
+      clipdist[i] = nir_fmul(&b, load, fragcoord_w);
+      b.shader->info.inputs_read |= BITFIELD64_BIT(var_slot);
+   }
+
+   /* Test each clip distance against zero and OR the results */
+   nir_def *cond = NULL;
+   for (unsigned i = 0; i < key->clip_distance_array_size; i++) {
+      nir_def *negative = nir_flt_imm(&b, clipdist[i], 0.0);
+      cond = cond ? nir_ior(&b, cond, negative) : negative;
+   }
+
+   /* Demote fragments where any clip distance is negative */
+   nir_demote_if(&b, cond);
+   b.shader->info.fs.uses_discard = true;
+
+   return b.shader;
+}
