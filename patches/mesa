+   /* Prolog last -> NONE */
+   ASSERT_EQ(get_flow(words[1]), VA_FLOW_NONE);
+   /* Main last -> NONE (main starts at word 2) */
+   ASSERT_EQ(get_flow(words[2 + 3]), VA_FLOW_NONE);
+   /* Epilog last -> END (epilog starts at word 6) */
+   ASSERT_EQ(get_flow(words[6 + 1]), VA_FLOW_END);
+
+   pan_fast_link_cleanup(&linked);
