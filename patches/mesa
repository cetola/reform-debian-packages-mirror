index 000000000000..dd852337903f
--- /dev/null
+++ b/src/panfrost/compiler/bifrost/valhall/test/test-fast-link.cpp
@@ -0,0 +1,183 @@
+/*
+ * Copyright © 2026 Google, Inc.
+ * SPDX-License-Identifier: MIT
+ */
+
+#include "pan_fast_link.h"
+#include "valhall_enums.h"
+
+#include <gtest/gtest.h>
+
+/* Helper: build a fake Valhall binary with N instructions padded to
+ * 128-byte alignment (matching the real compiler). The padding is
+ * zero-filled, which is NOT valid Valhall encoding. */
+static void
+build_fake_binary(std::vector<uint8_t> &buf, unsigned count)
+{
+   unsigned real_bytes = count * 8;
+   unsigned padded_bytes = ALIGN_POT(real_bytes, 128);
+   buf.resize(padded_bytes, 0); /* zero-fill padding */
+
+   uint64_t *instrs = (uint64_t *)buf.data();
+   for (unsigned i = 0; i < count; i++) {
+      enum va_flow flow = (i == count - 1) ? VA_FLOW_END : VA_FLOW_NONE;
+      instrs[i] = 0xDEAD0000 | i | ((uint64_t)flow << 59);
+   }
+}
+
+static enum va_flow
+get_flow(uint64_t instr)
+{
+   return (enum va_flow)((instr >> 59) & 0x1f);
+}
+
+TEST(FastLink, PrologMainConcat)
+{
+   std::vector<uint8_t> prolog_buf, main_buf;
+   build_fake_binary(prolog_buf, 4); /* 32 bytes real, 128 bytes padded */
+   build_fake_binary(main_buf, 8);   /* 64 bytes real, 128 bytes padded */
+
+   struct pan_shader_part prolog = {
+      .binary = prolog_buf.data(),
+      .size = (unsigned)prolog_buf.size(),
+      .last_instr_offset = 3 * 8,
+      .work_reg_count = 8,
+   };
+   struct pan_shader_part main_part = {
+      .binary = main_buf.data(),
+      .size = (unsigned)main_buf.size(),
+      .last_instr_offset = 7 * 8,
+      .work_reg_count = 32,
+   };
+
+   struct pan_linked_shader linked = {};
+   ASSERT_TRUE(pan_fast_link(&linked, &prolog, &main_part, NULL));
+
+   /* Prolog padding must be stripped: 4*8 (prolog real) + 128 (main full) */
+   ASSERT_EQ(linked.size, 4u * 8 + main_part.size);
+   ASSERT_EQ(linked.work_reg_count, 32u);
+
+   uint64_t *words = (uint64_t *)linked.binary;
+
+   /* Prolog's last instruction should have flow patched to NONE */
+   ASSERT_EQ(get_flow(words[3]), VA_FLOW_NONE);
+
+   /* Main starts immediately after prolog (no zero gap) */
+   ASSERT_NE(words[4], 0u); /* would be zero if padding leaked through */
+
+   /* Main's last instruction should still have FLOW_END */
+   ASSERT_EQ(get_flow(words[4 + 7]), VA_FLOW_END);
+
+   pan_fast_link_cleanup(&linked);
+}
+
+TEST(FastLink, MainEpilogConcat)
+{
+   std::vector<uint8_t> main_buf, epilog_buf;
+   build_fake_binary(main_buf, 8);   /* 64 bytes real, 128 bytes padded */
+   build_fake_binary(epilog_buf, 2); /* 16 bytes real, 128 bytes padded */
+
+   struct pan_shader_part main_part = {
+      .binary = main_buf.data(),
+      .size = (unsigned)main_buf.size(),
+      .last_instr_offset = 7 * 8,
+      .work_reg_count = 32,
+   };
+   struct pan_shader_part epilog = {
+      .binary = epilog_buf.data(),
+      .size = (unsigned)epilog_buf.size(),
+      .last_instr_offset = 1 * 8,
+      .work_reg_count = 16,
+   };
+
+   struct pan_linked_shader linked = {};
+   ASSERT_TRUE(pan_fast_link(&linked, NULL, &main_part, &epilog));
+
+   /* Main padding stripped: 8*8 (main real) + 128 (epilog full) */
+   ASSERT_EQ(linked.size, 8u * 8 + epilog.size);
+   ASSERT_EQ(linked.work_reg_count, 32u);
+
+   uint64_t *words = (uint64_t *)linked.binary;
+
+   /* Main's last instruction should have flow patched to NONE */
+   ASSERT_EQ(get_flow(words[7]), VA_FLOW_NONE);
+
+   /* Epilog starts immediately after main (no zero gap) */
+   ASSERT_NE(words[8], 0u);
+
+   /* Epilog's last instruction should still have FLOW_END */
+   ASSERT_EQ(get_flow(words[8 + 1]), VA_FLOW_END);
+
+   pan_fast_link_cleanup(&linked);
+}
+
+TEST(FastLink, PrologMainEpilogConcat)
+{
+   std::vector<uint8_t> prolog_buf, main_buf, epilog_buf;
+   build_fake_binary(prolog_buf, 2); /* 16 bytes real, 128 bytes padded */
+   build_fake_binary(main_buf, 4);   /* 32 bytes real, 128 bytes padded */
+   build_fake_binary(epilog_buf, 2); /* 16 bytes real, 128 bytes padded */
+
+   struct pan_shader_part prolog = {
+      .binary = prolog_buf.data(),
+      .size = (unsigned)prolog_buf.size(),
+      .last_instr_offset = 1 * 8,
+      .work_reg_count = 4,
+   };
+   struct pan_shader_part main_part = {
+      .binary = main_buf.data(),
+      .size = (unsigned)main_buf.size(),
+      .last_instr_offset = 3 * 8,
+      .work_reg_count = 32,
+   };
+   struct pan_shader_part epilog = {
+      .binary = epilog_buf.data(),
+      .size = (unsigned)epilog_buf.size(),
+      .last_instr_offset = 1 * 8,
+      .work_reg_count = 16,
+   };
+
+   struct pan_linked_shader linked = {};
+   ASSERT_TRUE(pan_fast_link(&linked, &prolog, &main_part, &epilog));
+
+   /* Both prolog and main padding stripped:
+    * 2*8 (prolog real) + 4*8 (main real) + 128 (epilog full) */
+   ASSERT_EQ(linked.size, 2u * 8 + 4u * 8 + epilog.size);
+   ASSERT_EQ(linked.work_reg_count, 32u);
+
+   uint64_t *words = (uint64_t *)linked.binary;
+
+   /* Prolog last -> NONE */
+   ASSERT_EQ(get_flow(words[1]), VA_FLOW_NONE);
+   /* Main last -> NONE (main starts at word 2) */
+   ASSERT_EQ(get_flow(words[2 + 3]), VA_FLOW_NONE);
+   /* Epilog last -> END (epilog starts at word 6) */
+   ASSERT_EQ(get_flow(words[6 + 1]), VA_FLOW_END);
+
+   pan_fast_link_cleanup(&linked);
+}
+
+TEST(FastLink, MainOnly)
+{
+   std::vector<uint8_t> main_buf;
+   build_fake_binary(main_buf, 4); /* 32 bytes real, 128 bytes padded */
+
+   struct pan_shader_part main_part = {
+      .binary = main_buf.data(),
+      .size = (unsigned)main_buf.size(),
+      .last_instr_offset = 3 * 8,
+      .work_reg_count = 16,
+   };
+
+   struct pan_linked_shader linked = {};
+   ASSERT_TRUE(pan_fast_link(&linked, NULL, &main_part, NULL));
+
+   /* No stripping needed - main is the final part, keeps full padded size */
+   ASSERT_EQ(linked.size, main_part.size);
+   ASSERT_EQ(linked.work_reg_count, 16u);
+
+   uint64_t *words = (uint64_t *)linked.binary;
+   ASSERT_EQ(get_flow(words[3]), VA_FLOW_END);
+
+   pan_fast_link_cleanup(&linked);
+}
