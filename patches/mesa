index 000000000000..9259d1b756ef
--- /dev/null
+++ b/src/panfrost/vulkan/panvk_linked_shader_cache.c
@@ -0,0 +1,142 @@
+/*
+ * Copyright © 2026 Google, Inc.
+ * SPDX-License-Identifier: MIT
+ */
+
+#include "panvk_linked_shader_cache.h"
+#include "panvk_device.h"
+
+#include "util/hash_table.h"
+#include "util/ralloc.h"
+
+static uint32_t
+panvk_linked_shader_key_hash(const void *data)
+{
+   return _mesa_hash_data(data, sizeof(struct panvk_linked_shader_key));
+}
+
+static bool
+panvk_linked_shader_key_equal(const void *a, const void *b)
+{
+   return memcmp(a, b, sizeof(struct panvk_linked_shader_key)) == 0;
+}
+
+void
+panvk_linked_shader_cache_init(struct panvk_linked_shader_cache *cache)
+{
+   cache->ht = _mesa_hash_table_create(NULL, panvk_linked_shader_key_hash,
+                                       panvk_linked_shader_key_equal);
+   simple_mtx_init(&cache->lock, mtx_plain);
+}
+
+void
+panvk_linked_shader_cache_destroy(struct panvk_linked_shader_cache *cache,
+                                  struct panvk_device *dev)
+{
+   hash_table_foreach(cache->ht, entry)
+   {
+      struct panvk_linked_shader_entry *e = entry->data;
+
+      panvk_pool_free_mem(&e->code_mem);
+      panvk_pool_free_mem(&e->spd);
+      ralloc_free((void *)entry->key);
+      ralloc_free(e);
+   }
+
+   _mesa_hash_table_destroy(cache->ht, NULL);
+   cache->ht = NULL;
+   simple_mtx_destroy(&cache->lock);
+}
+
+struct panvk_linked_shader_entry *
+panvk_linked_shader_cache_lookup(struct panvk_linked_shader_cache *cache,
+                                 const struct panvk_linked_shader_key *key)
+{
+   uint32_t hash = panvk_linked_shader_key_hash(key);
+
+   simple_mtx_lock(&cache->lock);
+   struct hash_entry *entry =
+      _mesa_hash_table_search_pre_hashed(cache->ht, hash, key);
+   simple_mtx_unlock(&cache->lock);
+
+   return entry ? entry->data : NULL;
+}
+
+struct panvk_linked_shader_entry *
+panvk_linked_shader_cache_insert(struct panvk_linked_shader_cache *cache,
+                                 struct panvk_device *dev,
+                                 const struct panvk_linked_shader_key *key,
+                                 const struct pan_linked_shader *linked)
+{
+   struct panvk_linked_shader_entry *entry =
+      rzalloc(NULL, struct panvk_linked_shader_entry);
+   if (!entry)
+      return NULL;
+
+   entry->work_reg_count = linked->work_reg_count;
+
+   if (linked->size) {
+      entry->code_mem = panvk_pool_upload_aligned(
+         &dev->mempools.exec, linked->binary, linked->size, 128);
+      if (!panvk_priv_mem_check_alloc(entry->code_mem)) {
+         ralloc_free(entry);
+         return NULL;
+      }
+   }
+
+   struct panvk_linked_shader_key *key_copy =
+      rzalloc(NULL, struct panvk_linked_shader_key);
+   if (!key_copy) {
+      panvk_pool_free_mem(&entry->code_mem);
+      ralloc_free(entry);
+      return NULL;
+   }
+   memcpy(key_copy, key, sizeof(*key));
+
+   uint32_t hash = panvk_linked_shader_key_hash(key);
+
+   simple_mtx_lock(&cache->lock);
+
+   /* Check if another thread inserted while we were linking */
+   struct hash_entry *existing =
+      _mesa_hash_table_search_pre_hashed(cache->ht, hash, key);
+   if (existing) {
+      simple_mtx_unlock(&cache->lock);
+      panvk_pool_free_mem(&entry->code_mem);
+      ralloc_free(key_copy);
+      ralloc_free(entry);
+      return existing->data;
+   }
+
+   _mesa_hash_table_insert_pre_hashed(cache->ht, hash, key_copy, entry);
+   simple_mtx_unlock(&cache->lock);
+
+   return entry;
+}
+
+void
+panvk_linked_shader_cache_invalidate(struct panvk_linked_shader_cache *cache,
+                                     const void *main_binary)
+{
+   if (!cache->ht)
+      return;
+
+   simple_mtx_lock(&cache->lock);
+
+   hash_table_foreach(cache->ht, entry)
+   {
+      const struct panvk_linked_shader_key *key = entry->key;
+
+      if (key->main_binary == main_binary) {
+         struct panvk_linked_shader_entry *e = entry->data;
+
+         panvk_pool_free_mem(&e->code_mem);
+         panvk_pool_free_mem(&e->spd);
+         ralloc_free((void *)entry->key);
+         ralloc_free(e);
+         _mesa_hash_table_remove(cache->ht, entry);
+      }
+   }
+
+   simple_mtx_unlock(&cache->lock);
+}
