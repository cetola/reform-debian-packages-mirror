#include "qcs6490-mnt-quasar.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/interrupt-controller/irq.h>

/ {
	model = "MNT Reform 2 with QCS6490 Quasar Module";
	compatible = "mntre,reform2", "mntre,quasar-qcs6490", "qcom,qcm6490";
	chassis-type = "laptop";

	backlight: backlight {
		compatible = "pwm-backlight";
		pwms = <&pm8350c_pwm 3 50000 0>;
		enable-gpios = <&tlmm 94 GPIO_ACTIVE_HIGH>;
		brightness-levels = <0 1000>;
		default-brightness-level = <50>;
		num-interpolated-steps = <100>;
		pinctrl-0 = <&backlight_enable>;
		pinctrl-names = "default";
		status = "okay";
	};

	usb3_con: usb3_con {
		compatible = "usb-a-connector";

		ports {
			#address-cells = <1>;
			#size-cells = <0>;

			port@0 {
				reg = <0>;

				usb3_con_hs_in: endpoint {
					remote-endpoint = <&usb_1_dwc3_hs>;
				};
			};

			port@1 {
				reg = <1>;

				usb3_con_ss_in: endpoint {
					remote-endpoint = <&usb_dp_qmpphy_out_usb>;
				};
			};
		};
	};
};

&dp_hot_plug_det {
	bias-disable;
};

&i2c6 {
	wm8960: codec@1a {
		compatible = "wlf,wm8960";
		reg = <0x1a>;
		#sound-dai-cells = <0>;
	};
};

&mdss_dp {
	status = "okay";

	aux-bus {
		panel: panel {
			compatible = "innolux,n125hce-gn1";
			// compatible = "edp-panel";
			power-supply = <&main_3v3>;
			backlight = <&backlight>;
			// FIXME: not wired up, fixed in V2 PCB
			// hpd-gpios = <&tlmm 47 GPIO_ACTIVE_HIGH>;
			no-hpd;

			status = "okay";

			port {
				panel_dp_in: endpoint {
					remote-endpoint = <&usb_dp_qmpphy_out_dp>;
				};
			};
		};
	};
};

&mdss_dp_out {
	data-lanes = <0 1>;
	link-frequencies = /bits/ 64 <1620000000 2700000000 5400000000>;
	remote-endpoint = <&usb_dp_qmpphy_dp_in>;
	pinctrl-names = "default";
	pinctrl-0 = <&dp_hot_plug_det>;
	status = "okay";
};

&pcie1 {
	perst-gpios = <&tlmm 2 GPIO_ACTIVE_LOW>;

	pinctrl-0 = <&pcie1_reset_n>, <&pcie1_wake_n>;
	pinctrl-names = "default";

	status = "okay";
};

&pcie1_phy {
	vdda-phy-supply = <&vreg_l10c_0p88>;
	vdda-pll-supply = <&vreg_l6b_1p2>;

	status = "okay";
};

&sound {
	model = "QCS6490-MNT-Reform2";
};

&sound_primary_codec {
	sound-dai = <&wm8960>;
};

&tlmm {
	backlight_enable: backlight-enable-state {
		pins = "gpio94";
		function = "gpio";
		output-enable;
	};

	pcie1_reset_n: pcie1-reset-n-state {
		pins = "gpio2";
		function = "gpio";
		drive-strength = <16>;
		output-low;
		bias-disable;
	};

	pcie1_wake_n: pcie1-wake-n-state {
		pins = "gpio3";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up;
	};
};

&usb_1_dwc3_hs {
	remote-endpoint = <&usb3_con_hs_in>;
};

&usb_1_qmpphy {
	ports {
		port@0 {
			#address-cells = <1>;
			#size-cells = <0>;

			/delete-node/ endpoint;

			usb_dp_qmpphy_out_dp: endpoint@0 {
				reg = <0>;

				data-lanes = <3 2>;
				remote-endpoint = <&panel_dp_in>;
				//remote-endpoint = <&dp0_connector_in>;
			};

			usb_dp_qmpphy_out_usb: endpoint@1 {
				reg = <1>;

				data-lanes = <1 0>;
				remote-endpoint = <&usb3_con_ss_in>;
			};
		};

		/*port@2 {
			// FIXME
			// mdss_dp connection
			status = "disabled";
		};*/
	};
};


