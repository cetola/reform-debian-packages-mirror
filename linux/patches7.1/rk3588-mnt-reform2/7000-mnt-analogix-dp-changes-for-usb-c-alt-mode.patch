+{
+	struct analogix_dp_device *dp = to_dp(connector);
+	enum drm_connector_status status = connector_status_disconnected;
+
+	if (dp->hpd_state)
+		status = connector_status_connected;
+
+	dev_info(dp->dev, "[analogix_dp_detect_ctx] %d\n", status);
+
+	return status;
+};
+
+static enum drm_mode_status analogix_dp_mode_valid(struct drm_connector *connector,
+						   const struct drm_display_mode *mode)
+{
+	struct analogix_dp_device *dp = to_dp(connector);
+	dev_info(dp->dev, "[analogix_dp_mode_valid] %d x %d @ %d kHz\n", mode->hdisplay, mode->vdisplay, mode->clock);
+
+	/* HACK: filter out non-working modes of Xreal Glasses */
+	if (mode->clock >= 220000 && mode->hdisplay == 1920 && mode->vdisplay == 1080)
+		return MODE_CLOCK_HIGH;
+
+	/* HACK: filter out other non-working modes */
+	/* TODO make configurable in DTS / module params */
+	if (mode->clock >= 250000 || mode->hdisplay == 2048)
+		return MODE_CLOCK_HIGH;
+	if (mode->hdisplay == 640)
+		return MODE_CLOCK_LOW;
+
+	return MODE_OK;
+}
