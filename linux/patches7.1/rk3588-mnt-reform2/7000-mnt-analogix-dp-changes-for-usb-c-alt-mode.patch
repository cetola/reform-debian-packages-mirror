+static void analogix_dp_hpd_timer_cb(struct timer_list *hpd_timer)
+{
+	struct analogix_dp_device *dp = to_dp(hpd_timer);
+	bool connected = !analogix_dp_get_plug_in_status(dp);
+	if (dp->hpd_state != connected) {
+		dp->hpd_state = connected;
+		schedule_work(&dp->hpd_work);
+	}
+
+	/* HACK: something in the kernel is messing with powered_down, causing i2c/aux transfers to fail.
+	 * Combat that here.
+	 */
+	if (dp->hpd_state) {
+		dp->connector.force = DRM_FORCE_ON;
+		dp->aux.powered_down = false;
+	}
+	mod_timer(hpd_timer, jiffies + msecs_to_jiffies(HPD_POLL_MS));
+}
+
+static void analogix_dp_hpd_work(struct work_struct *hpd_work)
+{
+	struct analogix_dp_device *dp = to_dp(hpd_work);
+	dev_info(dp->dev, "[analogix_dp_hpd_work] HPD state: %d\n", dp->hpd_state);
+	if (!dp->plat_data->skip_connector) {
+		dp->connector.status = dp->hpd_state ? connector_status_connected : connector_status_disconnected;
+		dp->connector.epoch_counter++;
+		drm_kms_helper_connector_hotplug_event(&dp->connector);
+	}
+}
