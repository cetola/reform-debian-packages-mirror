//	/delete-property/ power-domains;
//};

&lpass_aon {
	status = "okay";
};

&lpass_core {
	status = "okay";
};

&lpass_hm {
	status = "okay";
};

&lpasscc {
	status = "okay";
};

&pdc_reset {
	status = "okay";
};

&watchdog {
	status = "okay";
};

&wifi {
	/delete-property/ memory-region;
};
