    qcs8550/adreno: try not spamming the same BW vote over and over

diff --git a/drivers/gpu/drm/msm/adreno/a6xx_hfi.c b/drivers/gpu/drm/msm/adreno/a6xx_hfi.c
index 706ac3b..21dd4bf 100644
--- a/drivers/gpu/drm/msm/adreno/a6xx_hfi.c
+++ b/drivers/gpu/drm/msm/adreno/a6xx_hfi.c
@@ -907,16 +907,21 @@ static int a6xx_hfi_send_core_fw_start(struct a6xx_gmu *gmu)
 		sizeof(msg), NULL, 0);
 }
 
+static u32 prev_freq = 0xffffffff;
+
 int a6xx_hfi_set_freq(struct a6xx_gmu *gmu, u32 freq_index, u32 bw_index)
 {
 	struct a6xx_hfi_gx_bw_perf_vote_cmd msg = { 0 };
+	if (prev_freq == freq_index) return 0;
 
 	msg.ack_type = 1; /* blocking */
 	msg.freq = freq_index;
 	msg.bw = bw_index;
 
-	return a6xx_hfi_send_msg(gmu, HFI_H2F_MSG_GX_BW_PERF_VOTE, &msg,
+	int res = a6xx_hfi_send_msg(gmu, HFI_H2F_MSG_GX_BW_PERF_VOTE, &msg,
 		sizeof(msg), NULL, 0);
+	if (!res) prev_freq = freq_index;
+	return res;
 }
 
 int a6xx_hfi_send_prep_slumber(struct a6xx_gmu *gmu)
