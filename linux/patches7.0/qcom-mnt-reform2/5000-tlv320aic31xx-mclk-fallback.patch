Author: Lucie L. Hartmann <lukas@mntre.com>
Date:   Tue Jun 9 02:54:25 2026 +0200

    tlv320aic31xx: default to 12.288MHz sysclk if not set

diff --git a/sound/soc/codecs/tlv320aic31xx.c b/sound/soc/codecs/tlv320aic31xx.c
index cf5e991..c119446 100644
--- a/sound/soc/codecs/tlv320aic31xx.c
+++ b/sound/soc/codecs/tlv320aic31xx.c
@@ -887,8 +887,12 @@ static int aic31xx_setup_pll(struct snd_soc_component *component,
 	int i;
 
 	if (!aic31xx->sysclk || !aic31xx->p_div) {
-		dev_err(component->dev, "Master clock not supplied\n");
-		return -EINVAL;
+		dev_warn(component->dev, "Master clock not supplied, defaulting to 12288000 Hz.\n");
+		aic31xx->sysclk = 12288000;
+		aic31xx->sysclk_id = AIC31XX_PLL_CLKIN_MCLK;
+		aic31xx->p_div = 1;
+		snd_soc_component_update_bits(component, AIC31XX_CLKMUX, AIC31XX_PLL_CLKIN_MASK,
+					      aic31xx->sysclk_id << AIC31XX_PLL_CLKIN_SHIFT);
 	}
 	mclk_p = aic31xx->sysclk / aic31xx->p_div;
 
