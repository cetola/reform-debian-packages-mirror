	qcom,gsi-loader = "self";
	memory-region = <&ipa_fw_mem>;
	firmware-name = "qcom/sm8550/ipa_fws.mbn";
	status = "okay";
};

// TODO not in qcs dts
&iris {
	status = "okay";
};*/

&ice {
  status = "disabled";
};

&lpass_vamacro {
  status = "disabled";
};
&lpass_wsamacro {
  status = "disabled";
};
&lpass_wsa2macro {
  status = "disabled";
};
&lpass_txmacro {
  status = "disabled";
};
&lpass_rxmacro {
  status = "disabled";
};

// TODO not in qcs dts, but in sm8550
&gpi_dma1 {
	status = "okay";
};

&gpu {
	status = "okay";

	zap-shader {
		firmware-name = "qcom/qcs8550/a740_zap.mbn";
	};
};

&mdss {
	status = "okay";
};

&mdss_dp0 {
	/delete-property/ #sound-dai-cells;
	data-lanes = <0 1>;
	
	status = "okay";

	aux-bus {
		panel: panel {
			compatible = "innolux,n125hce-gn1";
			//compatible = "edp-panel";
			power-supply = <&main_3v3>;
			no-hpd;
			//backlight = <&backlight>;
			// hpd-gpios = <&tlmm 47 GPIO_ACTIVE_HIGH>;

			pinctrl-names = "default";
			pinctrl-0 = <&backlight_enable>;
			status = "okay";

			port {
				edp_panel_in: endpoint {
					//remote-endpoint = <&usb_dp_qmpphy_out_dp>;
					remote-endpoint = <&mdss_dp0_out>;
				};
			};
		};
	};

	ports {
		port@1 {
			reg = <1>;

			mdss_dp0_out: endpoint {
				link-frequencies = /bits/ 64 <1620000000 2700000000 5400000000>;
				remote-endpoint = <&edp_panel_in>;
				//remote-endpoint = <&usb_dp_qmpphy_dp_in>;
				//pinctrl-names = "default";
				//pinctrl-0 = <&dp_hot_plug_det>;
			};
		};
	};	
};

&mdss_dsi1 {
	vdda-supply = <&vreg_l3e_1p2>;
	status = "okay";
};

&mdss_dsi1_out {
	remote-endpoint = <&lt9611_a>;
	data-lanes = <0 1 2 3>;
};

&mdss_dsi1_phy {
	vdds-supply = <&vreg_l1e_0p88>;
	status = "okay";
};

&pcie0 {
	perst-gpios = <&tlmm 94 GPIO_ACTIVE_LOW>;
	wake-gpios = <&tlmm 96 GPIO_ACTIVE_HIGH>;

	pinctrl-0 = <&pcie0_default_state>, <&pcie0_reset_n>;
	pinctrl-names = "default";

	iommu-map = <0x0 &apps_smmu 0x1400 0x1>,
	<0x100 &apps_smmu 0x1401 0x1>,
	<0x208 &apps_smmu 0x1402 0x1>,
	<0x210 &apps_smmu 0x1403 0x1>,
	<0x218 &apps_smmu 0x1404 0x1>,
	<0x300 &apps_smmu 0x1407 0x1>,
	<0x400 &apps_smmu 0x1408 0x1>,
	<0x500 &apps_smmu 0x140c 0x1>,
	<0x501 &apps_smmu 0x140e 0x1>;

	msi-map = <0x00 &gic_its 0x1400 0x01
	0x100 0x7a 0x1401 0x01
	0x208 0x7a 0x1402 0x01
	0x210 0x7a 0x1403 0x01
	0x218 0x7a 0x1404 0x01
	0x300 0x7a 0x1407 0x01
	0x400 0x7a 0x1408 0x01
	0x500 0x7a 0x140c 0x01
	0x501 0x7a 0x140e 0x01>;

	status = "okay";
};

&pcie0_phy {
	vdda-phy-supply = <&vreg_l1e_0p88>;
	vdda-pll-supply = <&vreg_l3e_1p2>;

	status = "okay";
};

&lpass_tlmm {
	status = "disabled";
};

&pcie1 {
	perst-gpios = <&tlmm 97 GPIO_ACTIVE_LOW>;
	wake-gpios = <&tlmm 99 GPIO_ACTIVE_HIGH>;

	pinctrl-0 = <&pcie1_default_state>, <&pcie1_reset_n>;
	pinctrl-names = "default";

	iommu-map = <0x0 &apps_smmu 0x1480 0x1>,
	<0x100 &apps_smmu 0x1481 0x1>,
	<0x208 &apps_smmu 0x1482 0x1>,
	<0x210 &apps_smmu 0x1483 0x1>,
	<0x218 &apps_smmu 0x1484 0x1>,
	<0x300 &apps_smmu 0x1487 0x1>,
	<0x400 &apps_smmu 0x1488 0x1>,
	<0x500 &apps_smmu 0x148c 0x1>,
	<0x501 &apps_smmu 0x148e 0x1>;

	msi-map = <0x00 &gic_its 0x1480 0x01
	0x100 0x7a 0x1481 0x01
	0x208 0x7a 0x1482 0x01
	0x210 0x7a 0x1483 0x01
	0x218 0x7a 0x1484 0x01
	0x300 0x7a 0x1487 0x01
	0x400 0x7a 0x1488 0x01
	0x500 0x7a 0x148c 0x01
	0x501 0x7a 0x148e 0x01>;

	status = "okay";
};

&pcie1_phy {
	vdda-phy-supply = <&vreg_l3c_0p9>;
	vdda-pll-supply = <&vreg_l3e_1p2>;
	vdda-qref-supply = <&vreg_l1e_0p88>;

	status = "okay";
};

/* GPIO notes:
- gpio4: usb hub reset
- gpio5: uswitch_1 on som

uboot magic:
gpio set soc5
gpio clear soc4
gpio set soc4
*/

&pm8550_gpios {
	/* note: pm8550-gpio11 in uboot */
	sdc2_card_det_n: sdc2-card-det-state {
		pins = "gpio12";
		function = "normal";
		input-enable;
		output-disable;
		bias-pull-up;
		power-source = <1>; // 1.8 V
	};

	/* note: pm8550-gpio5 in uboot */
	volume_up_n: volume-up-n-state {
		pins = "gpio6";
		function = "normal";
		power-source = <1>;
		bias-pull-up;
		input-enable;
	};
};

&pm8550_pwm {
	status = "disabled";

	multi-led {
		color = <LED_COLOR_ID_RGB>;
		function = LED_FUNCTION_STATUS;

		#address-cells = <1>;
		#size-cells = <0>;

		led@1 {
			reg = <1>;
			color = <LED_COLOR_ID_RED>;
		};

		led@2 {
			reg = <2>;
			color = <LED_COLOR_ID_GREEN>;
		};

		led@3 {
			reg = <3>;
			color = <LED_COLOR_ID_BLUE>;
		};
	};
};

&pm8550b_eusb2_repeater {
	vdd18-supply = <&vreg_l15b_1p8>;
	vdd3-supply = <&vreg_l5b_3p1>;
};

&pon_pwrkey {
	status = "okay";
};

&pon_resin {
	linux,code = <KEY_VOLUMEDOWN>;
	status = "okay";
};

&qupv3_id_0 {
	status = "okay";
	firmware-name = "qcom/qcs8550/qupv3fw.elf";
};

// TODO crashy in uboot?
&qupv3_id_1 {
	status = "okay";
	firmware-name = "qcom/qcs8550/qupv3fw.elf";
};

// TODO qcom/qcs8550
&remoteproc_adsp {
	firmware-name = "qcom/qcs8550/adsp.mbn", "qcom/sm8550/adsp_dtb.mbn";
	status = "okay";
};

// TODO qcom/qcs8550
&remoteproc_cdsp {
	firmware-name = "qcom/qcs8550/cdsp.mbn", "qcom/sm8550/cdsp_dtb.mbn";
	status = "okay";
};

&sdhc_2 {
	cd-gpios = <&pm8550_gpios 12 GPIO_ACTIVE_LOW>;

	pinctrl-0 = <&sdc2_default>, <&sdc2_card_det_n>;
	pinctrl-1 = <&sdc2_sleep>, <&sdc2_card_det_n>;
	pinctrl-names = "default", "sleep";

	vmmc-supply = <&vreg_l9b_2p9>;
	vqmmc-supply = <&vreg_l8b_1p8>;

	bus-width = <4>;
	no-sdio;
	//no-mmc;

	status = "okay";
};

&tlmm {
	// reserved for SPI fingerprint sensor
	gpio-reserved-ranges = <32 8>;
  
	backlight_enable: backlight-enable-state {
		pins = "gpio22";
		function = "gpio";
		drive-strength = <16>;
		output-high;
		output-enable;
	};

	usb_hub_reset: usb-hub-state {
		pins = "gpio4";
		function = "gpio";
		drive-strength = <16>;
		output-low;
		output-enable;
	};

	usb_hub_switch: usb-hub-state {
		pins = "gpio5";
		function = "gpio";
		drive-strength = <16>;
		output-high;
		output-enable;
	};

	lt9611_irq_pin: lt9611-irq-state {
		pins = "gpio14";
		function = "gpio";
		drive-strength = <2>;
		bias-disable;
	};

	lt9611_rst_pin: lt9611-rst-state {
		pins = "gpio15";
		function = "gpio";
		drive-strength = <16>;
		output-high;
		bias-disable;
	};

	pcie0_reset_n: pcie0-reset-n-state {
		pins = "gpio94";
		function = "gpio";
		drive-strength = <16>;
		output-low;
		bias-disable;
	};

	pcie1_reset_n: pcie1-reset-n-state {
		pins = "gpio97";
		function = "gpio";
		drive-strength = <16>;
		output-low;
		bias-disable;
	};
	
	i2s_pins: i2s0-default-state {
		mclk-pins {
			pins = "gpio125";
			function = "audio_ext_mclk0";
			drive-strength = <0x08>;
			bias-disable;
			output-high;
		};

		sck-pins {
			pins = "gpio126";
			function = "i2s0_sck";
			drive-strength = <0x08>;
			bias-disable;
			output-high;
		};

		data0-pins {
			pins = "gpio127";
			function = "i2s0_data0";
			drive-strength = <0x08>;
			bias-disable;
		};

		data1-pins {
			pins = "gpio128";
			function = "i2s0_data1";
			drive-strength = <0x08>;
			bias-disable;
			output-high;
		};

		ws-pins {
			pins = "gpio129";
			function = "i2s0_ws";
			drive-strength = <0x08>;
			bias-disable;
			output-high;
		};
	};
};

&uart7 {
	status = "okay";
};

&ufs_mem_hc {
	reset-gpios = <&tlmm 210 GPIO_ACTIVE_LOW>;
	vcc-supply = <&vreg_l17b_2p5>;
	vcc-max-microamp = <1300000>;
	vccq-supply = <&vreg_l1g_1p2>;
	vccq-max-microamp = <1200000>;
	vdd-hba-supply = <&vreg_l3g_1p2>;

	status = "okay";
};

&ufs_mem_phy {
	vdda-phy-supply = <&vreg_l1d_0p88>;
	vdda-pll-supply = <&vreg_l3e_1p2>;

	status = "okay";
};

