From 73f0df017c29599c82f120cb595938843127da28 Mon Sep 17 00:00:00 2001
From: "Lukas F. Hartmann" <lukas@mntre.com>
Date: Wed, 28 May 2025 16:37:40 +0200
Subject: [PATCH 1/2] gschema: disable auto screen blank; enable accessibility
 menu by default

---
 schemas/20_reform.gschema.override | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/schemas/20_reform.gschema.override b/schemas/20_reform.gschema.override
index 70b883b..44f268f 100644
--- a/schemas/20_reform.gschema.override
+++ b/schemas/20_reform.gschema.override
@@ -27,6 +27,14 @@ picture-uri-dark = 'file:///usr/share/backgrounds/mnt-reform-next-y2k.jpg'
 primary-color = '#000000'
 picture-opacity = 100
 
+# disable "Automatic Screen Blank"
+[org.gnome.desktop.session]
+idle-delay = 0
+
+# Show the accessibility menu by default
+[org.gnome.desktop.a11y]
+always-show-universal-access-status = true
+
 # this is hogging Super+Escape by default
 [org.gnome.mutter.wayland.keybindings]
 restore-shortcuts = @as []
-- 
